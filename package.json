{
  "name": "telegram-gemini-summarizer-bot",
  "version": "1.0.0",
  "description": "Telegram bot for chat summarization using Gemini 3.1 Flash Lite and SQLite written in TypeScript.",
  "license": "MIT",
  "type": "module",
  "main": "dist/main.js",
  "private": true,
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "start": "tsx main.ts",
    "start:debug": "DEBUG=true tsx main.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test:db": "tsx test_db.ts",
    "test:main": "tsx test_main.ts",
    "test:parser": "tsx test_parser.ts",
    "test:utils": "tsx test_utils.ts",
    "test:summarizer": "tsx test_summarizer.ts",
    "test": "tsx test_db.ts && tsx test_main.ts && tsx test_parser.ts && tsx test_utils.ts && tsx test_summarizer.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "dependencies": {
    "@google/genai": "^2.5.0",
    "dotenv": "^16.4.5",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
}

