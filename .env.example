# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Debug Mode (set to true to show DEBUG logs; defaults to false/disabled)
# DEBUG=true

# Gemini API Settings (using the new google-genai SDK)
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite Database Location
DB_PATH=data/bot_messages.db

# Timezone for date formatting in prompts (e.g. Europe/Moscow, UTC, etc.)
DEFAULT_TIMEZONE=Europe/Moscow

# Language for bot interface and summaries ('en' or 'ru', defaults to 'en')
BOT_LANGUAGE=en

# Rate Limiting (disabled by default. Set RATE_LIMIT_MAX_REQUESTS > 0 to enable)
# RATE_LIMIT_MAX_REQUESTS=5
# RATE_LIMIT_WINDOW_SEC=3600

# Chat ID Authorization Whitelist (disabled by default. Comma-separated list of allowed chat IDs)
# ALLOWED_CHATS=-100123456789,-100987654321

