# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Debug Mode (set DEBUG=true/1 or LOG_LEVEL=debug to show DEBUG logs; defaults to false/disabled)
# DEBUG=true
# LOG_LEVEL=debug

# Gemini API Settings (using the new google-genai SDK)
GEMINI_API_KEY=your_gemini_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# SQLite Database Location (must not contain '..')
DB_PATH=data/bot_messages.db

# Timezone for date formatting in prompts (e.g. Europe/Moscow, UTC, etc.)
DEFAULT_TIMEZONE=Europe/Moscow

# Language for bot interface and summaries ('en' or 'ru', defaults to 'en')
BOT_LANGUAGE=en

# Rate Limiting (disabled by default, or when set to 0. Invalid or negative values fail-closed)
# RATE_LIMIT_MAX_REQUESTS=5
# RATE_LIMIT_WINDOW_SEC=3600

# Chat ID Authorization (Fail-Closed: no chats are allowed by default)
# To authorize specific chats, specify their IDs as a comma-separated list:
# ALLOWED_CHATS=-100123456789,-100987654321
#
# To explicitly bypass authorization and allow all chats, set this to true:
# ALLOW_ALL_CHATS=false

# PII Minimization Mode (set to true to replace real names/usernames in transcripts with stable pseudonyms)
# REDACT_USER_IDENTITIES=false

